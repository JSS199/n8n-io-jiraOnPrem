{
  "name": "n8n-nodes-JiraOnPrem",
  "version": "0.1.0",
  "description": "PoC JiraOnPrem declarative node for n8n",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "JiraOnPrem",
    "automation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/yourname/n8n-nodes-jira-poc",
  "author": {
    "name": "Your Name"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourname/n8n-nodes-jira-poc.git"
  },

  "main": "dist/index.js",

  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint nodes credentials --ext .ts"
  },

  "files": [
    "dist"
  ],

  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/JiraOnPrem.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Jira/JiraOnPrem.node.js"
    ]
  },

  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.50.0",
    "typescript": "^5.0.0"
  },

  "peerDependencies": {
    "n8n-workflow": "*"
  }
}